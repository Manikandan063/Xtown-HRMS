{
  "name": "rv-express-app",
  "version": "1.0.0",
  "description": "CLI tool to scaffold a modular Express.js app with role-based auth and Sequelize/Postgres setup.",
  "main": "server.js",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "sequelize-cli db:migrate",
    "migrate:undo": "sequelize-cli db:migrate:undo",
    "seed": "sequelize-cli db:seed:all",
    "seed:undo": "sequelize-cli db:seed:undo"
  },
  "keywords": [
    "modular",
    "express",
    "file-structure",
    "sequelize",
    "postgres",
    "auth",
    "starter"
  ],
  "author": "https://github.com/aravindh99",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.17.4",
    "node-zklib": "^1.3.0",
    "nodemailer": "^8.0.4",
    "pdfkit": "^0.17.2",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.7",
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "morgan": "^1.10.1",
    "nodemon": "^3.1.10",
    "sequelize-cli": "^6.6.3"
  }
}
